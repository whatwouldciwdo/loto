# ==========================================================================
# LOTO Application — Environment Configuration
# Copy this file to .env and fill in the real values.
# ==========================================================================

# --------------------------------------------------------------------------
# Database (PostgreSQL) — external server
# pgAdmin: http://10.8.140.69/pgadmin4/browser/
# Replace USER, PASSWORD and DB name with the real credentials.
# --------------------------------------------------------------------------
DATABASE_URL=postgresql://loto_user:CHANGE_ME@10.8.140.69:5432/loto_db

# --------------------------------------------------------------------------
# JWT Configuration
# --------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_random_string_at_least_32_characters_long

# --------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------
NODE_ENV=production
# Public URL of the app (used by the browser). Set to the server address.
NEXT_PUBLIC_API_URL=http://localhost:3000

# --------------------------------------------------------------------------
# WhatsApp Notifications (WAHA)
# Dashboard: http://10.8.140.67:8310/dashboard/
#   WHATSAPP_API_URL  -> WAHA base URL (no trailing slash)
#   WHATSAPP_API_KEY  -> WAHA API key (leave empty if the server has none)
#   WHATSAPP_SESSION  -> WAHA session name (default: "default")
# --------------------------------------------------------------------------
WHATSAPP_API_URL=http://10.8.140.67:8310
WHATSAPP_API_KEY=
WHATSAPP_SESSION=default

# Optional: phone number used by test-whatsapp.js (international format, no +)
WHATSAPP_TEST_PHONE=6287814111808
