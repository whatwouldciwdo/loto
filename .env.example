# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=loto_db
DATABASE_USER=loto_user
DATABASE_PASSWORD=loto_password_change_in_production
DATABASE_URL=postgresql://loto_user:loto_password_change_in_production@localhost:5432/loto_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production
REDIS_URL=redis://:redis_password_change_in_production@localhost:6379

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password_change_in_production
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=loto-files

# JWT Configuration
JWT_SECRET=your_jwt_secret_at_least_32_characters_long_change_in_production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# LDAP Configuration (untuk future Microsoft 365 integration)
LDAP_ENABLED=false
LDAP_URL=ldap://your-domain-controller.com:389
LDAP_BIND_DN=CN=bind-user,OU=Users,DC=company,DC=com
LDAP_BIND_PASSWORD=bind_user_password
LDAP_SEARCH_BASE=OU=Users,DC=company,DC=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# Application Configuration
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (optional, untuk notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=LOTO System <noreply@company.com>

# Export Configuration
EXPORT_TEMP_DIR=./temp/exports
EXPORT_MAX_FILE_SIZE=10485760
# 10MB in bytes

# Upload Configuration
UPLOAD_MAX_FILE_SIZE=5242880
# 5MB in bytes
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# WhatsApp Configuration (Wuzapi)
# NOTE: Use dot notation, NOT @ symbol (@ is interpreted as credentials)
WHATSAPP_API_URL=https://wuzapi-tceo8mb6myiz.sgp-wisanggeni.sumopod.my.id
WHATSAPP_API_KEY=Jp0hfP9l2RwRzMSVY1I1f7wIr7?3b4m0
